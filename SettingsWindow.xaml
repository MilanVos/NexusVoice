<Window x:Class="NexusVoice.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Instellingen — NexusVoice"
        Height="760" Width="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="⚙ Instellingen"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Azure API-sleutel, stemmen &amp; audioapparaten"
                           FontSize="13" Foreground="{StaticResource SubTextBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Azure Info -->
            <Border Grid.Row="2"
                    Background="#1A1A0A" BorderBrush="#554400"
                    BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="💡 Azure API-sleutel"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#FFC107" Margin="0,0,0,6"/>
                    <TextBlock FontSize="12" Foreground="{StaticResource SubTextBrush}"
                               TextWrapping="Wrap" LineHeight="20">
                        <Run Text="Ga naar"/>
                        <Run Text=" portal.azure.com" FontWeight="Bold" Foreground="#FFC107"/>
                        <Run Text=" → Speech service → Keys and Endpoint → kopieer Key 1 en Location/Region."/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Form -->
            <StackPanel Grid.Row="3">

                <!-- API Key -->
                <TextBlock Text="Azure Speech API-sleutel"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="KeyBox" FontSize="13" Padding="12,10"
                         Background="{StaticResource Surface2Brush}"
                         Foreground="{StaticResource TextBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         BorderThickness="1" CaretBrush="{StaticResource TextBrush}">
                    <TextBox.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- Region -->
                <TextBlock Text="Regio (bijv. germanywestcentral, westeurope)"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" Margin="0,14,0,6"/>
                <TextBox x:Name="RegionBox" FontSize="13" Padding="12,10"
                         Background="{StaticResource Surface2Brush}"
                         Foreground="{StaticResource TextBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         BorderThickness="1" CaretBrush="{StaticResource TextBrush}">
                    <TextBox.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- Divider -->
                <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,20,0,0"/>
                <TextBlock Text="🎤 Audio apparaten" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" Margin="0,14,0,14"/>

                <!-- Mic input -->
                <TextBlock FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,6">
                    <Run Text="🎙 Microfoon"/>
                    <Run Text="  (jij spreekt Nederlands hierin)"
                         FontWeight="Normal" FontSize="11"
                         Foreground="{StaticResource SubTextBrush}"/>
                </TextBlock>
                <ComboBox x:Name="InputDeviceBox" DisplayMemberPath="Name"/>

                <!-- TTS output -->
                <TextBlock FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" Margin="0,14,0,6">
                    <Run Text="🔊 Duits TTS uitvoer"/>
                    <Run Text="  (Discord microfoon — stel in op VB-Cable Input)"
                         FontWeight="Normal" FontSize="11"
                         Foreground="{StaticResource SubTextBrush}"/>
                </TextBlock>
                <ComboBox x:Name="OutputDeviceBox" DisplayMemberPath="Name"/>

                <!-- Loopback capture -->
                <TextBlock FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" Margin="0,14,0,6">
                    <Run Text="📡 Discord uitvoer (loopback)"/>
                    <Run Text="  (waar Discord-audio speelt — herkennt Duits)"
                         FontWeight="Normal" FontSize="11"
                         Foreground="{StaticResource SubTextBrush}"/>
                </TextBlock>
                <ComboBox x:Name="LoopbackDeviceBox" DisplayMemberPath="Name"/>

                <!-- Divider -->
                <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,20,0,0"/>
                <TextBlock Text="🗣 Stemmen" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" Margin="0,14,0,14"/>

                <!-- Dutch voice -->
                <TextBlock Text="Nederlandse stem"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                <ComboBox x:Name="DutchVoiceBox"/>

                <!-- German voice -->
                <TextBlock Text="Duitse stem"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" Margin="0,14,0,6"/>
                <ComboBox x:Name="GermanVoiceBox"/>

            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="Annuleren"
                        Style="{StaticResource IconButtonStyle}"
                        Padding="20,10" FontSize="13"
                        Margin="0,0,12,0" Click="CancelButton_Click"/>
                <Button Content="💾 Opslaan"
                        Background="{StaticResource NLBrush}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="24,10" FontSize="13"
                        Click="SaveButton_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
