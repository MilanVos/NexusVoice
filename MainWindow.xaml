<Window x:Class="NexusVoice.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:NexusVoice.Helpers"
        xmlns:models="clr-namespace:NexusVoice.Models"
        Title="NexusVoice"
        Height="780" Width="960"
        MinHeight="680" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Window.Resources>

        <DataTemplate x:Key="DutchMessageTemplate" DataType="{x:Type models:ConversationMessage}">
            <Grid Margin="0,5,60,5">
                <Border Style="{StaticResource CardStyle}"
                        BorderBrush="{StaticResource NLBrush}"
                        BorderThickness="2"
                        HorizontalAlignment="Left"
                        MaxWidth="520">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="{Binding SpeakerLabel}"
                                       FontWeight="Bold" FontSize="12"
                                       Foreground="{StaticResource NLBrush}"
                                       DockPanel.Dock="Left"/>
                            <TextBlock Text="{Binding TimeText}"
                                       FontSize="11"
                                       Foreground="{StaticResource SubTextBrush}"
                                       HorizontalAlignment="Right"/>
                        </DockPanel>
                        <TextBlock Text="{Binding OriginalText}"
                                   FontSize="14" Foreground="{StaticResource TextBrush}"
                                   TextWrapping="Wrap"/>
                        <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock Text="🇩🇪" FontSize="12" Margin="0,0,5,0"/>
                            <TextBlock Text="Duits" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource DEBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TranslatedText}"
                                   FontSize="13" Foreground="#B0C4E0"
                                   TextWrapping="Wrap" FontStyle="Italic"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="GermanMessageTemplate" DataType="{x:Type models:ConversationMessage}">
            <Grid Margin="60,5,0,5">
                <Border Style="{StaticResource CardStyle}"
                        BorderBrush="{StaticResource DEBrush}"
                        BorderThickness="2"
                        HorizontalAlignment="Right"
                        MaxWidth="520">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="{Binding TimeText}"
                                       FontSize="11"
                                       Foreground="{StaticResource SubTextBrush}"
                                       DockPanel.Dock="Left" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SpeakerLabel}"
                                       FontWeight="Bold" FontSize="12"
                                       Foreground="{StaticResource DEBrush}"
                                       HorizontalAlignment="Right"/>
                        </DockPanel>
                        <TextBlock Text="{Binding OriginalText}"
                                   FontSize="14" Foreground="{StaticResource TextBrush}"
                                   TextWrapping="Wrap" TextAlignment="Right"/>
                        <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,2">
                            <TextBlock Text="Nederlands" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource NLBrush}" Margin="0,0,5,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="🇳🇱" FontSize="12"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TranslatedText}"
                                   FontSize="13" Foreground="#B0C4E0"
                                   TextWrapping="Wrap" FontStyle="Italic" TextAlignment="Right"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <helpers:MessageTemplateSelector x:Key="MessageSelector"
            DutchTemplate="{StaticResource DutchMessageTemplate}"
            GermanTemplate="{StaticResource GermanMessageTemplate}"/>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left">
                    <TextBlock Text="◆" FontSize="20" Foreground="{StaticResource NLBrush}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="Nexus" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="Voice" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource DEBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="🇳🇱 ↔ 🇩🇪" FontSize="13"
                               Foreground="{StaticResource SubTextBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="ClearButton" Content="🗑 Wissen"
                            Style="{StaticResource IconButtonStyle}"
                            Click="ClearButton_Click" Margin="0,0,8,0" FontSize="13"/>
                    <Button x:Name="SettingsButton" Content="⚙ Instellingen"
                            Style="{StaticResource IconButtonStyle}"
                            Click="SettingsButton_Click" FontSize="13"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Live panels: real-time recognized text -->
        <Grid Grid.Row="1" Margin="16,12,16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- NL → DE panel -->
            <Border Grid.Column="0"
                    Background="{StaticResource NLDimBrush}"
                    BorderBrush="{StaticResource NLBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="14,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Ellipse x:Name="NLDot" Width="8" Height="8"
                                 Fill="{StaticResource SubTextBrush}"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="🇳🇱 Jij spreekt" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource NLBrush}"/>
                    </StackPanel>
                    <TextBlock x:Name="NLInterimText"
                               Text="Spreek Nederlands..."
                               FontSize="13" Foreground="{StaticResource SubTextBrush}"
                               TextWrapping="Wrap" MinHeight="20"/>
                    <TextBlock x:Name="DEInterimText"
                               Text=""
                               FontSize="12" Foreground="{StaticResource DEBrush}"
                               TextWrapping="Wrap" FontStyle="Italic"
                               Margin="0,4,0,0" MinHeight="16"/>
                </StackPanel>
            </Border>

            <!-- DE → NL panel -->
            <Border Grid.Column="2"
                    Background="{StaticResource DEDimBrush}"
                    BorderBrush="{StaticResource DEBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="14,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Ellipse x:Name="DEDot" Width="8" Height="8"
                                 Fill="{StaticResource SubTextBrush}"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="🇩🇪 Duitser spreekt" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource DEBrush}"/>
                    </StackPanel>
                    <TextBlock x:Name="DERecogText"
                               Text="Luistert via Discord..."
                               FontSize="13" Foreground="{StaticResource SubTextBrush}"
                               TextWrapping="Wrap" MinHeight="20"/>
                    <TextBlock x:Name="NLTranslatedText"
                               Text=""
                               FontSize="12" Foreground="{StaticResource NLBrush}"
                               TextWrapping="Wrap" FontStyle="Italic"
                               Margin="0,4,0,0" MinHeight="16"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Conversation log -->
        <ScrollViewer x:Name="ConversationScroller"
                      Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,4">
            <StackPanel>
                <StackPanel x:Name="EmptyState"
                            HorizontalAlignment="Center"
                            Margin="0,40,0,0">
                    <TextBlock Text="💬" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Gespreklog verschijnt hier"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource SubTextBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="SetupHint"
                               Text="⚠ Configureer eerst je Azure API-sleutel via Instellingen"
                               FontSize="12" Foreground="#FFC107"
                               HorizontalAlignment="Center" Margin="0,12,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
                <ItemsControl x:Name="ConversationList"
                              ItemTemplateSelector="{StaticResource MessageSelector}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Start/Stop button bar -->
        <Border Grid.Row="3"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Setup tip -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="🎙 Microfoon → Duits TTS → Virtuele kabel → Discord"
                               FontSize="11" Foreground="{StaticResource SubTextBrush}"/>
                    <TextBlock Text="🔊 Discord uitvoer → Loopback → NL ondertitels"
                               FontSize="11" Foreground="{StaticResource SubTextBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Start / Stop button -->
                <Button x:Name="ToggleButton"
                        Grid.Column="1"
                        Content="🎙  Start Vertaling"
                        Background="{StaticResource NLBrush}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        FontSize="15"
                        Padding="36,14"
                        Click="ToggleButton_Click"/>

                <!-- Right placeholder -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="SessionTimer"
                               Text="" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource SubTextBrush}"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="4" Background="{StaticResource Surface2Brush}" Padding="16,0">
            <DockPanel VerticalAlignment="Center">
                <Ellipse x:Name="StatusDot" Width="8" Height="8"
                         Fill="{StaticResource SubTextBrush}"
                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="StatusText"
                           Text="Klaar om te starten"
                           FontSize="12" Foreground="{StaticResource SubTextBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
